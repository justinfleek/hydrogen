-- | Standard UUID5 namespaces for Hydrogen.
-- |
-- | Namespaces ensure deterministic identity across billion-agent scale:
-- | - Same namespace + name → same UUID (always)
-- | - Different content types get different namespaces
-- | - Enables algebraic reasoning about identity

module Hydrogen.Schema.Attestation.UUID5.Namespaces
  ( -- * UUID5 Type
    UUID5(UUID5)
  -- * Core Namespaces
  , nsElement
  , nsEvent
  , nsAttestation
  , nsContact
  -- * UI Component Namespaces
  , nsButton
  , nsToggle
  , nsTab
  , nsTabPanel
  , nsAccordionTrigger
  , nsAccordionContent
  , nsOTPInput
  , nsOTPDigit
  -- * 3D/Scene Namespaces
