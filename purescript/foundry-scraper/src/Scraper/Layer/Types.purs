-- | Z-indexed layer types for scraped DOM components.
-- |
-- | When scraping a website, components are extracted as layers with:
-- |   - UUID5 identifier (deterministic from content)
-- |   - Z-index for stacking order
-- |   - Bounding box in viewport coordinates
-- |   - Visual content (Hydrogen Element)
-- |
-- | The scraper produces a LayerStack, the dashboard renders it,
-- | and the comparator diffs original PNG against reconstruction.
-- |
-- | DEPENDENCIES:
-- |   - Hydrogen.Element.Core (Element type)
-- |   - Hydrogen.Schema.Dimension (Pixel coordinates)
-- |   - Hydrogen.Schema.Elevation (ZIndex)
-- |
-- | DEPENDENTS:
-- |   - Scraper.Dashboard.View (renders layers)
-- |   - Scraper.Compare.Diff (compares layers)

module Scraper.Layer.Types
  ( -- * UUID5 (Deterministic Identifier)
    UUID5
  , mkUUID5
  , unUUID5
  
  -- * Bounding Box
  , BoundingBox
  , mkBoundingBox
  , boxX
  , boxY
  , boxWidth
  , boxHeight
  , boxRight
  , boxBottom
  , boxContains
  , boxIntersects
  
  -- * Layer
  , Layer
  , mkLayer
  , layerId
  , layerZIndex
  , layerBounds
